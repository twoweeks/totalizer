{
  "name": "twg-totalizer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:only-errors": "biome check --diagnostic-level=error",
    "prepare": "/bin/sh -c 'if type git >/dev/null 2>&1; then git config core.hooksPath .git-hooks; else true; fi'"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "es-toolkit": "1.44.0",
    "preact": "10.28.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@preact/preset-vite": "2.10.3",
    "sass": "1.97.3",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
